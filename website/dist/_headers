/*
  Content-Security-Policy: default-src 'none'; script-src 'self' https://posthog.fuddata.com/ https://static.cloudflareinsights.com/ https://challenges.cloudflare.com/; frame-src https://challenges.cloudflare.com; connect-src 'self' https://posthog.fuddata.com/; img-src 'self'; style-src 'self'; font-src 'self'; form-action 'self'; frame-ancestors 'none'; media-src 'self';
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  Access-Control-Allow-Origin: https://www.fuddata.com https://posthog.fuddata.com

/*.js
  Content-Type: application/javascript; charset=utf-8

/*.png
  Content-Type: image/png

/*.svg
  Content-Type: image/svg+xml; charset=utf-8

/favicon.ico
  ! Content-Security-Policy
  Cache-Control: public, max-age=31536000, immutable

/static/css/*
  ! Content-Security-Policy

/static/font/*
  ! Content-Security-Policy
  Cache-Control: public, max-age=31536000, immutable

/static/icon/*
  ! Content-Security-Policy

/static/img/*
  ! Content-Security-Policy

/assets/*.mp4
  ! Content-Security-Policy
  Cache-Control: public, max-age=31536000, immutable
